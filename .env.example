APP_NAME=锋煊Agent
APP_ENV=dev
APP_DEBUG=true
APP_PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=agent_backend

REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_PERSIST_DIRECTORY=./data/chroma

JWT_SECRET_KEY=please_change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

DEFAULT_TEMPERATURE=0.7
DEFAULT_CONTEXT_WINDOW=8192
SECRET_ENCRYPT_KEY=please_change_encrypt_key_32chars

# china-testing/bazi 本地路径（留空则禁用八字内置工具）
BAZI_HOME=D:/code/tools/bazi
# BAZI_PYTHON=D:/code/tools/bazi/.venv/Scripts/python.exe
# BAZI_SUBPROCESS_TIMEOUT_SECONDS=90
# BAZI_MAX_OUTPUT_CHARS=16000
